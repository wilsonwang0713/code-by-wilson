---
// website/src/components/Nav.astro
const base = import.meta.env.BASE_URL;
const links = [
  { href: `${base}docs/`, label: 'Docs' },
  { href: `${base}blog/`, label: 'Blog' },
  { href: `${base}changelog/`, label: 'Changelog' },
  { href: `${base}download/`, label: 'Download' },
  { href: `${base}sponsor/`, label: 'Sponsor' },
];
---
<nav>
  <a href={base} class="brand">
    <span class="brand-mark"><span></span><span></span><span></span><span></span></span>
    <span class="brand-name">Code-by-wire</span>
  </a>
  <div class="nav-right">
    <div class="nav-links">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
    <a
      href="https://github.com/luojiahai/code-by-wire"
      class="icon-link"
      aria-label="GitHub"
      title="GitHub"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.333-1.755-1.333-1.755-1.089-.744.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.605-2.665-.303-5.466-1.332-5.466-5.93 0-1.31.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.5 11.5 0 0 1 12 5.803c1.02.005 2.047.138 3.003.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.61-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.604-.014 2.896-.014 3.286 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
    </a>
  </div>
</nav>

<style>
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 48px;
    border-bottom: 1px solid var(--border);
    max-width: 1280px;
    margin: 0 auto;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .brand-mark {
    display: flex;
    gap: 3px;
    align-items: flex-end;
    height: 20px;
  }
  .brand-mark span {
    width: 5px;
    background: #fff;
    border-radius: 1px;
  }
  .brand-mark span:nth-child(1) {
    height: 35%;
    opacity: 0.16;
  }
  .brand-mark span:nth-child(2) {
    height: 60%;
    opacity: 0.35;
  }
  .brand-mark span:nth-child(3) {
    height: 80%;
    opacity: 0.6;
  }
  .brand-mark span:nth-child(4) {
    height: 100%;
    opacity: 1;
  }
  .brand-name {
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.01em;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .nav-links {
    display: flex;
    gap: 36px;
    font-size: 14px;
    color: var(--text-dim);
  }
  .nav-links a:hover {
    color: var(--text);
  }
  .icon-link {
    color: var(--text-dim);
    display: flex;
  }
  .icon-link:hover {
    color: var(--text);
  }
  @media (max-width: 640px) {
    nav {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
      padding: 16px 20px;
    }
    .nav-right {
      width: 100%;
      justify-content: space-between;
    }
    .nav-links {
      gap: 16px;
      flex-wrap: wrap;
    }
  }
</style>
