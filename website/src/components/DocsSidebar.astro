---
// website/src/components/DocsSidebar.astro
const base = import.meta.env.BASE_URL;

interface Props {
  docs: { id: string; data: { title: string; order: number } }[];
  currentId: string;
}

const { docs, currentId } = Astro.props;
---
<div class="docs-sidebar-root">
  <button
    id="docs-sidebar-toggle"
    class="docs-sidebar-toggle"
    aria-expanded="false"
    aria-controls="docs-sidebar"
  >
    <svg class="icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="3" y1="6" x2="21" y2="6" />
      <line x1="3" y1="12" x2="21" y2="12" />
      <line x1="3" y1="18" x2="21" y2="18" />
    </svg>
    <svg class="icon-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="5" y1="5" x2="19" y2="19" />
      <line x1="19" y1="5" x2="5" y2="19" />
    </svg>
    <span>Menu</span>
  </button>
  <div id="docs-sidebar-backdrop" class="docs-sidebar-backdrop"></div>
  <aside id="docs-sidebar" class="docs-sidebar">
    <nav>
      <ul>
        {
          docs.map((doc) => (
            <li>
              <a
                href={`${base}docs/${doc.id}/`}
                aria-current={doc.id === currentId ? 'page' : undefined}
              >
                {doc.data.title}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </aside>
</div>

<style>
  .docs-sidebar-root {
    grid-area: sidebar;
  }
  .docs-sidebar-toggle {
    display: none;
  }
  .docs-sidebar-backdrop {
    display: none;
  }
  .docs-sidebar {
    position: sticky;
    top: 32px;
  }
  .docs-sidebar nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .docs-sidebar nav li {
    margin-bottom: 4px;
  }
  .docs-sidebar nav a {
    display: block;
    padding: 6px 10px;
    border-radius: 6px;
    color: var(--text-dim);
    font-size: 14px;
  }
  .docs-sidebar nav a:hover {
    color: var(--text);
  }
  .docs-sidebar nav a[aria-current='page'] {
    color: var(--text);
    background: var(--bg-raised);
    font-weight: 600;
  }
  @media (max-width: 768px) {
    .docs-sidebar-toggle {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--text);
      font-size: 14px;
      padding: 10px 14px;
      border: 1px solid var(--border);
      border-radius: 8px;
      margin-bottom: 24px;
    }
    .docs-sidebar-toggle .icon-close {
      display: none;
    }
    .docs-sidebar-toggle[aria-expanded='true'] .icon-open {
      display: none;
    }
    .docs-sidebar-toggle[aria-expanded='true'] .icon-close {
      display: block;
    }
    .docs-sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: 280px;
      max-width: 80vw;
      background: var(--bg-raised);
      border-right: 1px solid var(--border);
      padding: 24px 20px;
      transform: translateX(-100%);
      transition: transform 0.2s ease;
      z-index: 50;
      overflow-y: auto;
    }
    .docs-sidebar.is-open {
      transform: translateX(0);
    }
    .docs-sidebar-backdrop.is-open {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 40;
    }
  }
</style>

<script>
  const toggle = document.getElementById('docs-sidebar-toggle');
  const sidebar = document.getElementById('docs-sidebar');
  const backdrop = document.getElementById('docs-sidebar-backdrop');

  function openDrawer() {
    sidebar?.classList.add('is-open');
    backdrop?.classList.add('is-open');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    sidebar?.classList.remove('is-open');
    backdrop?.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    if (sidebar?.classList.contains('is-open')) {
      closeDrawer();
    } else {
      openDrawer();
    }
  });

  backdrop?.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeDrawer();
  });

  sidebar?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeDrawer);
  });
</script>
