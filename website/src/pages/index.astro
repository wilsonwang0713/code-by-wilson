---
// website/src/pages/index.astro
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import screenshot from '../assets/screenshot.png';
const base = import.meta.env.BASE_URL;
const features = [
  {
    title: 'Every session in one rail',
    description:
      'Manage every session running on your machine from one rail: grouped by project, searchable, each flagging its live state.',
  },
  {
    title: 'Drive, fork, or just watch',
    description:
      'Spawn a session in an embedded terminal, fork a live one, adopt one you started elsewhere, or observe it read-only.',
  },
  {
    title: 'The full transcript',
    description: 'Every message, tool call, and result, reconstructed from disk and rendered cleanly.',
  },
  {
    title: 'The telemetry the CLI hides',
    description:
      'Context pressure, spend, token throughput, duty cycle, git, tasks, subagents, and background shells, live per session.',
  },
  {
    title: 'The whole story',
    description:
      'A cross-session Stats view with a year-long contributions calendar and exact, never-estimated totals.',
  },
  {
    title: 'Your rate limits in view',
    description:
      "Your account's rate-limit windows, read straight from disk, with live reset countdowns.",
  },
];
---
<BaseLayout
  title="FlightDeck · Pilot every Claude Code session on your machine"
  description="One live dashboard for every session: state, full transcript, an embedded terminal, and telemetry."
>
  <section class="hero">
    <h1>Pilot every Claude Code session on your <span class="dim">machine</span>.</h1>
    <p class="hero-sub">
      One live dashboard for every session: state, full transcript, an embedded terminal, and
      telemetry.
    </p>
    <div class="hero-ctas">
      <a href={`${base}download/`} class="btn-primary">Download</a>
    </div>
  </section>

  <section class="screenshot-section">
    <div class="screenshot-frame">
      <div class="chrome"><span></span><span></span><span></span></div>
      <Image
        src={screenshot}
        alt="FlightDeck showing a live Claude Code session with the session rail, transcript, and telemetry panels"
        width={1600}
        priority
      />
    </div>
  </section>

  <section class="features">
    <div class="section-head">
      <h2>Features</h2>
      <p>Needs Claude Code installed locally. Open the app and every session already running on your machine is there.</p>
    </div>
    <div class="feature-grid">
      {
        features.map((feature) => (
          <div class="feature">
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    max-width: 1280px;
    margin: 0 auto;
    padding: 120px 48px 96px;
  }
  h1 {
    font-weight: 600;
    font-size: 54px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 28px;
    max-width: 24ch;
  }
  h1 .dim {
    color: var(--text-dim);
  }
  .hero-sub {
    font-size: 19px;
    color: var(--text-dim);
    max-width: 46ch;
    margin-bottom: 40px;
  }
  .hero-ctas {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }
  .btn-primary {
    font-weight: 600;
    font-size: 15px;
    line-height: 1;
    background: #fff;
    color: #0a0a0c;
    padding: 14px 24px;
    border-radius: 8px;
    display: inline-block;
  }
</style>

<style>
  .screenshot-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 48px 96px;
  }
  .screenshot-frame {
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-raised);
  }
  .screenshot-frame .chrome {
    display: flex;
    gap: 6px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
  }
  .screenshot-frame .chrome span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border-strong);
  }
  .screenshot-frame :global(img) {
    width: 100%;
    display: block;
  }
  .features {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 48px 120px;
  }
  .section-head {
    margin-bottom: 56px;
  }
  .section-head h2 {
    font-size: 30px;
    font-weight: 600;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .section-head p {
    color: var(--text-dim);
    font-size: 16px;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }
  .feature {
    background: var(--bg);
    padding: 32px;
  }
  .feature h3 {
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 10px;
  }
  .feature p {
    color: var(--text-dim);
    font-size: 14px;
    line-height: 1.6;
  }
</style>

<style>
  @media (max-width: 640px) {
    .hero {
      padding: 64px 20px 48px;
    }
    h1 {
      font-size: 34px;
      max-width: 100%;
    }
    .hero-sub {
      font-size: 16px;
    }
    .screenshot-section {
      padding: 0 20px 64px;
    }
    .features {
      padding: 0 20px 64px;
    }
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
