---
// website/src/pages/download.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const releaseBase = 'https://github.com/luojiahai/code-by-wire/releases/latest/download';
const groups = [
  {
    id: 'macos',
    label: 'macOS',
    platforms: [
      { name: 'Apple Silicon', file: 'Code-by-wire-arm64.dmg' },
      { name: 'Intel', file: 'Code-by-wire-x64.dmg' },
    ],
  },
  {
    id: 'windows',
    label: 'Windows',
    platforms: [
      { name: 'x64', file: 'Code-by-wire-Setup-x64.exe' },
      { name: 'ARM64', file: 'Code-by-wire-Setup-arm64.exe' },
    ],
  },
];
---
<BaseLayout
  title="Download — Code-by-wire"
  description="Download Code-by-wire for macOS or Windows."
>
  <main class="download">
    <h1>Download</h1>
    <p class="lead">
      One click starts the download — always the latest release. You'll need
      <a href="https://docs.anthropic.com/en/docs/claude-code">Claude Code</a> installed locally,
      so there are sessions to observe and control.
    </p>

    {
      groups.map((group) => (
        <section id={group.id} class="platform-group">
          <h2>{group.label}</h2>
          <table>
            <tbody>
              {group.platforms.map((p) => (
                <tr>
                  <td class="platform">{p.name}</td>
                  <td>
                    <a href={`${releaseBase}/${p.file}`} class="file-link">
                      {p.file}
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      ))
    }

    <h2>Build from source</h2>
    <pre><code>pnpm install
pnpm rebuild:native
pnpm dist       # macOS
pnpm dist:win   # Windows</code></pre>
    <p class="note">
      A locally built app is unsigned: on macOS the first launch may need a right-click → Open,
      or clearing the quarantine flag with
      <code>xattr -dr com.apple.quarantine /Applications/Code-by-wire.app</code>; on Windows,
      SmartScreen may warn — click More info → Run anyway.
    </p>
  </main>
</BaseLayout>

<style>
  .download {
    max-width: 760px;
    margin: 0 auto;
    padding: 96px 48px;
  }
  .download h1 {
    font-weight: 600;
    font-size: 40px;
    margin-bottom: 24px;
  }
  .lead {
    color: var(--text-dim);
    font-size: 17px;
    line-height: 1.6;
    margin-bottom: 48px;
  }
  .lead a {
    text-decoration: underline;
  }
  .platform-group {
    margin-bottom: 40px;
  }
  .platform-group h2 {
    font-weight: 600;
    font-size: 22px;
    margin-bottom: 16px;
  }
  .download h2 {
    font-weight: 600;
    font-size: 22px;
    margin: 40px 0 16px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }
  td {
    padding: 14px 18px;
    border-top: 1px solid var(--border);
  }
  tr:first-child td {
    border-top: none;
  }
  .platform {
    color: var(--text-dim);
    width: 40%;
  }
  .file-link {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 13px;
    text-decoration: underline;
  }
  pre {
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    overflow-x: auto;
    margin-bottom: 20px;
  }
  code {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 13px;
  }
  .note {
    color: var(--text-dim);
    font-size: 14px;
    line-height: 1.7;
  }
  .note code {
    background: var(--bg-raised);
    padding: 2px 6px;
    border-radius: 4px;
  }
  @media (max-width: 640px) {
    .download {
      padding: 64px 20px;
    }
    .download h1 {
      font-size: 32px;
    }
  }
</style>
