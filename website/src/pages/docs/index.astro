---
// website/src/pages/docs/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const pages = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Docs — Code-by-wire" description="Documentation for Code-by-wire.">
  <main class="index-page">
    <h1>Docs</h1>
    <ul>
      {
        pages.map((page) => (
          <li>
            <a href={`${base}docs/${page.id}/`}>{page.data.title}</a>
            <p>{page.data.description}</p>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>

<style>
  .index-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 96px 48px;
  }
  .index-page h1 {
    font-weight: 600;
    font-size: 40px;
    margin-bottom: 40px;
  }
  .index-page ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .index-page li {
    border-top: 1px solid var(--border);
    padding: 24px 0;
  }
  .index-page li:last-child {
    border-bottom: 1px solid var(--border);
  }
  .index-page a {
    font-size: 18px;
    font-weight: 600;
  }
  .index-page a:hover {
    color: var(--text-dim);
  }
  .index-page p {
    color: var(--text-dim);
    font-size: 14px;
    margin-top: 6px;
  }
  @media (max-width: 640px) {
    .index-page {
      padding: 64px 20px;
    }
    .index-page h1 {
      font-size: 32px;
    }
  }
</style>
