---
// website/src/pages/docs/index.astro
import { getCollection } from 'astro:content';
import { sortDocsNav } from '../../lib/docs-nav';

const base = import.meta.env.BASE_URL;
const docs = sortDocsNav(await getCollection('docs'));
const firstPage = docs[0];

return Astro.redirect(`${base}docs/${firstPage.id}/`);
---
