---
// website/src/pages/docs/[...slug].astro
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { sortDocsNav } from '../../lib/docs-nav';

export async function getStaticPaths() {
  const pages = await getCollection('docs');
  const firstPage = sortDocsNav(pages)[0];

  return [
    ...pages.map((page) => ({
      params: { slug: page.id as string | undefined },
      props: { page },
    })),
    { params: { slug: undefined }, props: { page: firstPage } },
  ];
}

const { page } = Astro.props;
const { Content, headings } = await render(page);
---
<DocsLayout
  title={`${page.data.title} · FlightDeck docs`}
  description={page.data.description}
  currentId={page.id}
  headings={headings}
>
  <h1>{page.data.title}</h1>
  <div class="prose">
    <Content />
  </div>
</DocsLayout>

<style>
  h1 {
    font-weight: 600;
    font-size: 36px;
    margin-bottom: 40px;
  }
  @media (max-width: 640px) {
    h1 {
      font-size: 30px;
    }
  }
</style>
