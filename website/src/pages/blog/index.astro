---
// website/src/pages/blog/index.astro
import { getCollection } from 'astro:content';
import NarrowLayout from '../../layouts/NarrowLayout.astro';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime(),
);
---
<NarrowLayout title="Blog · FlightDeck" description="News and updates from FlightDeck.">
  <h1>Blog</h1>
  <ul>
    {
      posts.map((post) => (
        <li>
          <a href={`${base}blog/${post.id}/`}>{post.data.title}</a>
          <p>{post.data.description}</p>
          <time class="mono">{post.data.publishDate}</time>
        </li>
      ))
    }
  </ul>
</NarrowLayout>

<style>
  h1 {
    font-weight: 600;
    font-size: 40px;
    margin-bottom: 40px;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  li {
    border-top: 1px solid var(--border);
    padding: 24px 0;
  }
  li:last-child {
    border-bottom: 1px solid var(--border);
  }
  a {
    font-size: 18px;
    font-weight: 600;
  }
  a:hover {
    color: var(--text-dim);
  }
  p {
    color: var(--text-dim);
    font-size: 14px;
    margin-top: 6px;
  }
  time {
    color: var(--text-faint);
    font-size: 12px;
    display: block;
    margin-top: 10px;
  }
  @media (max-width: 640px) {
    h1 {
      font-size: 32px;
    }
  }
</style>
