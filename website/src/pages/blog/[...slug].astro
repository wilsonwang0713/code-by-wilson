---
// website/src/pages/blog/[...slug].astro
import { getCollection, render } from 'astro:content';
import NarrowLayout from '../../layouts/NarrowLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<NarrowLayout title={`${post.data.title} — Code-by-wire blog`} description={post.data.description}>
  <h1>{post.data.title}</h1>
  <time class="mono post-date">{post.data.publishDate}</time>
  <div class="content-body">
    <Content />
  </div>
</NarrowLayout>

<style>
  h1 {
    font-weight: 600;
    font-size: 36px;
    margin-bottom: 12px;
  }
  .post-date {
    color: var(--text-faint);
    font-size: 13px;
    display: block;
    margin-bottom: 40px;
  }
  .content-body :global(h2) {
    font-weight: 600;
    font-size: 22px;
    margin: 40px 0 16px;
  }
  .content-body :global(p) {
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .content-body :global(ul) {
    padding-left: 20px;
    margin-bottom: 16px;
  }
  .content-body :global(li) {
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 8px;
  }
  .content-body :global(a) {
    text-decoration: underline;
  }
  .content-body :global(strong) {
    color: var(--text);
  }
  .content-body :global(code) {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.9em;
    background: var(--bg-raised);
    padding: 2px 6px;
    border-radius: 4px;
  }
  @media (max-width: 640px) {
    h1 {
      font-size: 30px;
    }
  }
</style>
