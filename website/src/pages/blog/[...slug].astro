---
// website/src/pages/blog/[...slug].astro
import { getCollection, render } from 'astro:content';
import NarrowLayout from '../../layouts/NarrowLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<NarrowLayout title={`${post.data.title} · Code-by-wire blog`} description={post.data.description}>
  <h1>{post.data.title}</h1>
  <time class="mono post-date">{post.data.publishDate}</time>
  <div class="prose">
    <Content />
  </div>
</NarrowLayout>

<style>
  h1 {
    font-weight: 600;
    font-size: 36px;
    margin-bottom: 12px;
  }
  .post-date {
    color: var(--text-faint);
    font-size: 13px;
    display: block;
    margin-bottom: 40px;
  }
  @media (max-width: 640px) {
    h1 {
      font-size: 30px;
    }
  }
</style>
