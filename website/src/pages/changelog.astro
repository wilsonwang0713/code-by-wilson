---
// website/src/pages/changelog.astro
import NarrowLayout from '../layouts/NarrowLayout.astro';
import { renderChangelog } from '../lib/changelog';
// Vite resolves `?raw` imports against this module's own source location and
// inlines the file content at build time, so it is immune to Astro 7's
// "prerender" build step relocating this page's frontmatter into
// dist/.prerender/chunks/ (which breaks any fileURLToPath(import.meta.url)-based
// relative path — that path would resolve against the *chunk's* location, not
// this file's, since Rollup emits it under a different directory depth).
import changelogRaw from '../../../CHANGELOG.md?raw';

// The real CHANGELOG.md's own leading "# Changelog" line would otherwise
// duplicate this page's own <h1> above — strip just that line, keep
// everything else (the intro paragraph, then every version section).
const changelogHtml = renderChangelog(changelogRaw.replace(/^# Changelog\n+/, ''));
---
<NarrowLayout title="Changelog — Code-by-wire" description="Every notable change to Code-by-wire.">
  <h1>Changelog</h1>
  <div class="prose" set:html={changelogHtml} />
</NarrowLayout>

<style>
  h1 {
    font-weight: 600;
    font-size: 40px;
    margin-bottom: 40px;
  }
  .prose :global(h2) {
    font-size: 24px;
    margin: 48px 0 16px;
  }
  .prose :global(h2:first-child) {
    margin-top: 0;
  }
  .prose :global(h3) {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    margin: 24px 0 12px;
  }
  @media (max-width: 640px) {
    h1 {
      font-size: 32px;
    }
  }
</style>
