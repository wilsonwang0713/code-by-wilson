---
// website/src/pages/sponsor.astro
import NarrowLayout from '../layouts/NarrowLayout.astro';
---
<NarrowLayout title="Sponsor · FlightDeck" description="Support FlightDeck development.">
  <h1>Sponsor</h1>
  <p class="lead">
    FlightDeck is a personal project, built and maintained in spare time. If it's useful to
    you, here's how to support it.
  </p>
  <div class="sponsor-links">
    <a href="https://github.com/sponsors/wilsonwang0713" class="sponsor-card">
      <span class="sponsor-icon">♥</span>
      <span>
        <strong>GitHub Sponsors</strong>
        <span class="sponsor-desc">Recurring or one-time, through GitHub.</span>
      </span>
    </a>
    <a href="https://buymeacoffee.com/wilsonwang0713" class="sponsor-card">
      <span class="sponsor-icon">☕</span>
      <span>
        <strong>Buy Me a Coffee</strong>
        <span class="sponsor-desc">A one-off way to say thanks.</span>
      </span>
    </a>
  </div>
</NarrowLayout>

<style>
  h1 {
    font-weight: 600;
    font-size: 40px;
    margin-bottom: 24px;
  }
  .lead {
    color: var(--text-dim);
    font-size: 17px;
    line-height: 1.6;
    margin-bottom: 48px;
  }
  .sponsor-links {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .sponsor-card {
    display: flex;
    align-items: center;
    gap: 20px;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
  }
  .sponsor-card:hover {
    border-color: var(--border-strong);
  }
  .sponsor-icon {
    font-size: 28px;
  }
  .sponsor-card strong {
    display: block;
    font-size: 16px;
    margin-bottom: 4px;
  }
  .sponsor-desc {
    color: var(--text-dim);
    font-size: 14px;
  }
  @media (max-width: 640px) {
    h1 {
      font-size: 32px;
    }
    .sponsor-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }
</style>
