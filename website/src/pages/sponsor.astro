---
// website/src/pages/sponsor.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Sponsor — Code-by-wire" description="Support Code-by-wire development.">
  <main class="sponsor">
    <h1>Sponsor</h1>
    <p class="lead">
      Code-by-wire is a personal project, built and maintained in spare time. If it's useful to
      you, here's how to support it.
    </p>
    <div class="sponsor-links">
      <a href="https://github.com/sponsors/luojiahai" class="sponsor-card">
        <span class="sponsor-icon">♥</span>
        <span>
          <strong>GitHub Sponsors</strong>
          <span class="sponsor-desc">Recurring or one-time, through GitHub.</span>
        </span>
      </a>
      <a href="https://buymeacoffee.com/luojiahai" class="sponsor-card">
        <span class="sponsor-icon">☕</span>
        <span>
          <strong>Buy Me a Coffee</strong>
          <span class="sponsor-desc">A one-off way to say thanks.</span>
        </span>
      </a>
    </div>
  </main>
</BaseLayout>

<style>
  .sponsor {
    max-width: 760px;
    margin: 0 auto;
    padding: 96px 48px;
  }
  .sponsor h1 {
    font-weight: 600;
    font-size: 40px;
    margin-bottom: 24px;
  }
  .lead {
    color: var(--text-dim);
    font-size: 17px;
    line-height: 1.6;
    margin-bottom: 48px;
  }
  .sponsor-links {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .sponsor-card {
    display: flex;
    align-items: center;
    gap: 20px;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
  }
  .sponsor-card:hover {
    border-color: var(--border-strong);
  }
  .sponsor-icon {
    font-size: 28px;
  }
  .sponsor-card strong {
    display: block;
    font-size: 16px;
    margin-bottom: 4px;
  }
  .sponsor-desc {
    color: var(--text-dim);
    font-size: 14px;
  }
</style>
