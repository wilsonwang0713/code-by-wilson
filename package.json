{
  "name": "code-by-wire",
  "private": true,
  "version": "0.1.12",
  "description": "The cockpit for local Claude Code.",
  "author": "luojiahai",
  "license": "MIT",
  "homepage": "https://github.com/luojiahai/code-by-wire",
  "repository": {
    "type": "git",
    "url": "https://github.com/luojiahai/code-by-wire.git"
  },
  "bugs": {
    "url": "https://github.com/luojiahai/code-by-wire/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.3",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,node-pty",
    "icon": "electron scripts/make-icon.mjs",
    "dist": "electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --publish never",
    "dist:win": "electron-vite build && electron-builder --win --publish never",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fontsource-variable/cascadia-mono": "^5.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "acorn": "^8.17.0",
    "better-sqlite3": "^12.10.0",
    "lucide-react": "^1.17.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "js-yaml": "^4.2.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
